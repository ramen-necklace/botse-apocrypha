---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Ornament from '../../components/Ornament.astro';
import { categorySlug } from '../../lib/categories';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dateStr = post.data.date.toLocaleDateString('ru-RU', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const catSlug = categorySlug(post.data.category);

const rawTitle = post.data.title?.trim();
const cleanBody = post.body
  .replace(/<https?:\/\/[^>\s]+>/g, '')
  .replace(/\bhttps?:\/\/\S+/g, '')
  .replace(/[#>*_`\[\]\(\)!]/g, '')
  .replace(/\s+/g, ' ')
  .trim();
const displayTitle = rawTitle || cleanBody.slice(0, 80) + (cleanBody.length > 80 ? '…' : '') || `${post.data.category} · ${dateStr}`;
const pageTitle = rawTitle || `${post.data.category} · ${dateStr}`;
---

<Base title={`${pageTitle} · Апокриф BotSE`}>
  <article class="post">
    <header class="post-head">
      <a href={`${base}/category/${catSlug}/`} class="cat">{post.data.category}</a>
      <h1>{displayTitle}</h1>
      <p class="meta muted">
        <time datetime={post.data.date.toISOString()}>{dateStr}</time>
      </p>
      {post.data.tags.length > 0 && (
        <p class="tags">
          {post.data.tags.map((t) => <span class="tag">#{t}</span>)}
        </p>
      )}
      <Ornament />
    </header>

    {post.data.cover && (
      <img class="cover" src={`${base}/${post.data.cover.replace(/^\//, '')}`} alt="" />
    )}

    <div class="prose dropcap">
      <Content />
    </div>

    {post.data.sources.length > 0 && (
      <section class="sources">
        <h2>Внешние ссылки</h2>
        <ul>
          {post.data.sources.map((s) => (
            <li><a href={s.url} rel="noopener noreferrer" target="_blank">{s.label}</a></li>
          ))}
        </ul>
      </section>
    )}

    {post.data.telegram_url && (
      <aside class="media-notice">
        <p>К статье прикреплён файл в Telegram.</p>
        <a class="tg-btn" href={post.data.telegram_url} rel="noopener noreferrer" target="_blank">
          Скачать файл (Telegram) →
        </a>
      </aside>
    )}

    <footer class="post-foot">
      <Ornament />
    </footer>
  </article>
</Base>

<style>
  .post { max-width: 760px; margin: 0 auto; }
  .post-head { text-align: center; padding-top: 0.5rem; }
  .cat {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--gold);
    border: 0;
  }
  .meta {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    font-size: 0.92rem;
    margin: 0.4rem 0 0.6rem;
  }
  .tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.3rem; }
  .cover {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 0 0 1.5rem;
  }
  .prose :global(p) { margin-bottom: 1.1em; }
  .prose :global(img) {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 1rem 0;
  }
  .prose :global(h2) { margin-top: 2rem; }
  .prose :global(a) {
    word-break: break-word;
  }
  .sources {
    border-top: 1px solid var(--border);
    margin-top: 2.5rem;
    padding-top: 1.5rem;
  }
  .sources h2 { font-size: 1.1rem; }
  .sources ul { padding-left: 1.2rem; }
  .sources li { margin-bottom: 0.3rem; }
  .media-notice {
    border: 1px solid var(--gold-dim);
    background: rgba(201, 169, 97, 0.05);
    padding: 1rem 1.2rem;
    margin: 2rem 0;
    border-radius: var(--radius);
    text-align: center;
  }
  .tg-btn {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    border: 1px solid var(--gold);
    padding: 0.5rem 1.2rem;
    border-radius: var(--radius);
    color: var(--gold-bright);
  }
  .tg-btn:hover { background: rgba(201, 169, 97, 0.1); border-bottom-color: var(--gold); }
  .post-foot { text-align: center; margin-top: 2rem; }
</style>
