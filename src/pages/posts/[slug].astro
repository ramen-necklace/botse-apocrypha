---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Ornament from '../../components/Ornament.astro';
import { categorySlug } from '../../lib/categories';

function strip(body: string): string {
  return body
    .replace(/<https?:\/\/[^>\s]+>/g, '')
    .replace(/\bhttps?:\/\/\S+/g, '')
    .replace(/[#>*_`\[\]\(\)!]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function titleOf(p: CollectionEntry<'posts'>): string {
  const raw = p.data.title?.trim();
  if (raw) return raw;
  const body = strip(p.body);
  if (body) return body.slice(0, 60) + (body.length > 60 ? '…' : '');
  return p.data.category;
}

export async function getStaticPaths() {
  const all = await getCollection('posts');
  const byCat = new Map<string, CollectionEntry<'posts'>[]>();
  for (const p of all) {
    const list = byCat.get(p.data.category) ?? [];
    list.push(p);
    byCat.set(p.data.category, list);
  }
  // в каждой категории: сначала новые
  for (const list of byCat.values()) {
    list.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  }

  return all.map((post) => {
    const list = byCat.get(post.data.category)!;
    const idx = list.findIndex((p) => p.slug === post.slug);
    // newer = тот, что свежее этого (выше в desc-сортировке), older = тот, что старее
    const newer = idx > 0 ? list[idx - 1] : null;
    const older = idx < list.length - 1 ? list[idx + 1] : null;
    return { params: { slug: post.slug }, props: { post, newer, older } };
  });
}

const { post, newer, older } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dateStr = post.data.date.toLocaleDateString('ru-RU', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const catSlug = categorySlug(post.data.category);
const displayTitle = titleOf(post);
const pageTitle = post.data.title?.trim() || `${post.data.category} · ${dateStr}`;
---

<Base title={`${pageTitle} · Апокриф BotSE`}>
  <article class="post">
    <nav class="crumbs muted" aria-label="Хлебные крошки">
      <a href={`${base}/`}>Лента</a>
      <span aria-hidden="true">›</span>
      <a href={`${base}/category/${catSlug}/`}>{post.data.category}</a>
    </nav>

    <header class="post-head">
      <h1>{displayTitle}</h1>
      <p class="meta muted">
        <time datetime={post.data.date.toISOString()}>{dateStr}</time>
      </p>
      {post.data.tags.length > 0 && (
        <p class="tags">
          {post.data.tags.map((t) => <span class="tag">#{t}</span>)}
        </p>
      )}
      <Ornament />
    </header>

    {post.data.cover && (
      <img class="cover" src={`${base}/${post.data.cover.replace(/^\//, '')}`} alt="" />
    )}

    <div class="prose dropcap">
      <Content />
    </div>

    {post.data.sources.length > 0 && (
      <section class="sources">
        <h2>Внешние ссылки</h2>
        <ul>
          {post.data.sources.map((s) => (
            <li><a href={s.url} rel="noopener noreferrer" target="_blank">{s.label}</a></li>
          ))}
        </ul>
      </section>
    )}

    {post.data.telegram_url && (
      <aside class="media-notice">
        <p>К статье прикреплён файл в Telegram.</p>
        <a class="tg-btn" href={post.data.telegram_url} rel="noopener noreferrer" target="_blank">
          Скачать файл (Telegram) →
        </a>
      </aside>
    )}

    {(older || newer) && (
      <nav class="neighbors" aria-label="Соседние посты в категории">
        {older ? (
          <a class="neighbor older" href={`${base}/posts/${older.slug}/`}>
            <span class="dir">← Ранее в «{post.data.category}»</span>
            <span class="ttl">{titleOf(older)}</span>
          </a>
        ) : <span class="neighbor placeholder"></span>}
        {newer ? (
          <a class="neighbor newer" href={`${base}/posts/${newer.slug}/`}>
            <span class="dir">Позже в «{post.data.category}» →</span>
            <span class="ttl">{titleOf(newer)}</span>
          </a>
        ) : <span class="neighbor placeholder"></span>}
      </nav>
    )}

    <footer class="post-foot">
      <Ornament />
    </footer>
  </article>
</Base>

<style>
  .post { max-width: 760px; margin: 0 auto; }
  .crumbs {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.85rem;
    padding: 0.25rem 0 0.75rem;
  }
  .crumbs a { color: var(--text-dim); border: 0; }
  .crumbs a:hover { color: var(--gold); }
  .post-head { text-align: center; padding-top: 0.25rem; }
  .meta {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    font-size: 0.92rem;
    margin: 0.4rem 0 0.6rem;
  }
  .tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.3rem; }
  .cover {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 0 0 1.5rem;
  }
  .prose :global(p) { margin-bottom: 1.1em; }
  .prose :global(img) {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 1rem 0;
  }
  .prose :global(h2) { margin-top: 2rem; }
  .prose :global(a) { word-break: break-word; }
  .sources {
    border-top: 1px solid var(--border);
    margin-top: 2.5rem;
    padding-top: 1.5rem;
  }
  .sources h2 { font-size: 1.1rem; }
  .sources ul { padding-left: 1.2rem; }
  .sources li { margin-bottom: 0.3rem; }
  .media-notice {
    border: 1px solid var(--gold-dim);
    background: rgba(201, 169, 97, 0.05);
    padding: 1rem 1.2rem;
    margin: 2rem 0;
    border-radius: var(--radius);
    text-align: center;
  }
  .tg-btn {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    border: 1px solid var(--gold);
    padding: 0.5rem 1.2rem;
    border-radius: var(--radius);
    color: var(--gold-bright);
  }
  .tg-btn:hover { background: rgba(201, 169, 97, 0.1); border-bottom-color: var(--gold); }
  .post-foot { text-align: center; margin-top: 2rem; }

  .neighbors {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 2.5rem;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }
  .neighbor {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: inherit;
    transition: border-color 0.15s;
  }
  .neighbor:hover { border-color: var(--gold-dim); }
  .neighbor .dir {
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: var(--gold-dim);
    letter-spacing: 0.04em;
  }
  .neighbor .ttl {
    font-size: 0.95rem;
    color: var(--text);
  }
  .neighbor.newer { text-align: right; }
  .neighbor.placeholder { border: 0; padding: 0; }
  @media (max-width: 560px) {
    .neighbors { grid-template-columns: 1fr; }
    .neighbor.newer { text-align: left; }
  }
</style>
