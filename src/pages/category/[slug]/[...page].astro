---
import { getCollection } from 'astro:content';
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import CategoryChips from '../../../components/CategoryChips.astro';
import PostCard from '../../../components/PostCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { CATEGORIES, categorySlug, type Category } from '../../../lib/categories';

export const getStaticPaths = (async ({ paginate }) => {
  const all = await getCollection('posts');
  const counts: Record<string, number> = {};
  for (const p of all) counts[p.data.category] = (counts[p.data.category] ?? 0) + 1;

  return CATEGORIES.flatMap((cat) => {
    const posts = all
      .filter((p) => p.data.category === cat)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    return paginate(posts, {
      pageSize: 20,
      params: { slug: categorySlug(cat) },
      props: { category: cat, counts },
    });
  });
}) satisfies GetStaticPaths;

interface Props {
  category: Category;
  counts: Record<string, number>;
  page: Page<CollectionEntry<'posts'>>;
}
const { category, counts, page } = Astro.props as Props;
const slug = categorySlug(category);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const hrefForPage = (n: number) =>
  n === 1 ? `${base}/category/${slug}/` : `${base}/category/${slug}/${n}/`;

function pluralPosts(n: number): string {
  const mod10 = n % 10;
  const mod100 = n % 100;
  if (mod10 === 1 && mod100 !== 11) return 'материал';
  if ([2, 3, 4].includes(mod10) && ![12, 13, 14].includes(mod100)) return 'материала';
  return 'материалов';
}

const total = page.total;
const pageSuffix = page.currentPage > 1 ? ` · стр. ${page.currentPage}` : '';
---

<Base title={`${category}${pageSuffix} · Апокриф BotSE`}>
  <CategoryChips active={slug} counts={counts} />

  <header class="head">
    <h1>{category}</h1>
    <span class="muted count">{total} {pluralPosts(total)}</span>
  </header>

  {page.data.length === 0 ? (
    <p class="muted">Пока в этой категории пусто.</p>
  ) : (
    <div class="grid">
      {page.data.map((p) => <PostCard post={p} />)}
    </div>
  )}

  <Pagination
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    hrefForPage={hrefForPage}
  />
</Base>

<style>
  .head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0.5rem 0 0.75rem;
  }
  .head h1 { margin: 0; }
  .count { font-size: 0.85rem; }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
    margin-top: 1rem;
  }
  @media (min-width: 720px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
