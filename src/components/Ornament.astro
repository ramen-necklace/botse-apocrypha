---
// Тонкий золотой разделитель. Минималистичная версия — точка по центру + линии.
interface Props {
  size?: number;
}
const { size = 20 } = Astro.props;
---

<div class="ornament" aria-hidden="true">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size * 6}
    height={size}
    viewBox="0 0 120 20"
    fill="none"
    stroke="currentColor"
    stroke-width="1"
  >
    <line x1="0" y1="10" x2="52" y2="10" />
    <line x1="68" y1="10" x2="120" y2="10" />
    <circle cx="60" cy="10" r="2" />
  </svg>
</div>

<style>
  .ornament {
    display: flex;
    justify-content: center;
    color: var(--gold-dim);
    margin: 1rem 0;
    opacity: 0.6;
  }
</style>
