---
import { CATEGORIES, categorySlug } from '../lib/categories';

interface Props {
  active?: string;
  counts?: Record<string, number>;
}
const { active, counts = {} } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="chips-wrap" aria-label="Категории">
  <div class="chips">
    <a href={`${base}/`} class:list={['chip', { active: !active }]}>Все</a>
    {CATEGORIES.map((cat) => {
      const slug = categorySlug(cat);
      const n = counts[cat] ?? 0;
      return (
        <a
          href={`${base}/category/${slug}/`}
          class:list={['chip', { active: active === slug }]}
        >
          {cat}
          {n > 0 && <span class="count">{n}</span>}
        </a>
      );
    })}
  </div>
</nav>

<style>
  .chips-wrap {
    position: relative;
    padding: 0.4rem 0 0.8rem;
  }
  .chips {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-display);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-dim);
    white-space: nowrap;
    transition: border-color 0.15s, color 0.15s;
  }
  .chip:hover {
    border-color: var(--gold-dim);
    color: var(--gold);
  }
  .chip.active {
    border-color: var(--gold);
    color: var(--gold-bright);
    box-shadow: var(--shadow-gold);
  }
  .count {
    font-size: 0.68rem;
    color: var(--text-dim);
    background: rgba(201, 169, 97, 0.1);
    padding: 0 0.32rem;
    border-radius: 999px;
  }

  /* На мобильнике — горизонтальный скролл и градиент-фейд справа,
     чтобы намекнуть, что чипы можно скроллить. */
  @media (max-width: 640px) {
    .chips-wrap {
      mask-image: linear-gradient(to right, black calc(100% - 24px), transparent);
      -webkit-mask-image: linear-gradient(to right, black calc(100% - 24px), transparent);
    }
    .chips {
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x proximity;
      scrollbar-width: none;
      padding-right: 1.5rem;
    }
    .chips::-webkit-scrollbar { display: none; }
    .chip { scroll-snap-align: start; }
  }
</style>
