---
import { CATEGORIES, categorySlug } from '../lib/categories';

interface Props {
  active?: string;
  counts?: Record<string, number>;
}
const { active, counts = {} } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="chips" aria-label="Категории">
  <a
    href={`${base}/`}
    class:list={['chip', { active: !active }]}
  >
    Все
  </a>
  {CATEGORIES.map((cat) => {
    const slug = categorySlug(cat);
    const n = counts[cat] ?? 0;
    return (
      <a
        href={`${base}/category/${slug}/`}
        class:list={['chip', { active: active === slug }]}
      >
        {cat}
        {n > 0 && <span class="count">{n}</span>}
      </a>
    );
  })}
</nav>

<style>
  .chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.5rem 0 1rem;
    overflow-x: auto;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    padding: 0.35rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-dim);
    white-space: nowrap;
    transition: all 0.15s;
  }
  .chip:hover {
    border-color: var(--gold-dim);
    color: var(--gold);
  }
  .chip.active {
    border-color: var(--gold);
    color: var(--gold-bright);
    box-shadow: var(--shadow-gold);
  }
  .count {
    font-size: 0.72rem;
    color: var(--text-dim);
    background: rgba(201, 169, 97, 0.1);
    padding: 0 0.35rem;
    border-radius: 999px;
  }
  @media (max-width: 600px) {
    .chips {
      flex-wrap: nowrap;
      scroll-snap-type: x mandatory;
    }
    .chip { scroll-snap-align: start; }
  }
</style>
