---
import type { CollectionEntry } from 'astro:content';
import { categorySlug } from '../lib/categories';

interface Props {
  post: CollectionEntry<'posts'>;
}
const { post } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const d = post.data.date;
const dateStr = d.toLocaleDateString('ru-RU', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const catSlug = categorySlug(post.data.category);
const excerpt = post.body
  .replace(/<https?:\/\/[^>\s]+>/g, '')
  .replace(/\bhttps?:\/\/\S+/g, '')
  .replace(/[#>*_`\[\]\(\)!]/g, '')
  .replace(/\s+/g, ' ')
  .trim()
  .slice(0, 220);

const postHref = `${base}/posts/${post.slug}/`;
const categoryHref = `${base}/category/${catSlug}/`;
---

<article class="card">
  {post.data.cover && (
    <div class="cover">
      <img src={`${base}/${post.data.cover.replace(/^\//, '')}`} alt="" loading="lazy" />
    </div>
  )}
  <div class="body">
    <div class="meta">
      <a href={categoryHref} class="cat">{post.data.category}</a>
      <time datetime={d.toISOString()}>{dateStr}</time>
    </div>
    <h2 class="title">
      <a href={postHref} class="title-link">{post.data.title}</a>
    </h2>
    {excerpt && <p class="excerpt">{excerpt}{post.body.length > 220 ? '…' : ''}</p>}
    {post.data.telegram_url && (
      <div class="footer">
        <span class="badge">📎 файл в Telegram</span>
      </div>
    )}
  </div>
</article>

<style>
  .card {
    position: relative;
    border: 1px solid var(--border);
    background: var(--bg-card);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .card:hover {
    border-color: var(--gold);
    box-shadow: var(--shadow-gold);
    transform: translateY(-2px);
  }
  .cover { aspect-ratio: 16 / 9; overflow: hidden; border-bottom: 1px solid var(--border); }
  .cover img { width: 100%; height: 100%; object-fit: cover; }
  .body { padding: 1rem 1.2rem 1.2rem; }
  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.82rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }
  /* категория должна быть кликабельна отдельно — выше невидимого overlay'я */
  .cat {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    color: var(--gold);
    letter-spacing: 0.04em;
    border: 0;
  }
  .cat:hover { color: var(--gold-bright); }
  .title {
    font-size: 1.15rem;
    margin: 0 0 0.4rem;
    line-height: 1.3;
    overflow-wrap: anywhere;     /* длинные URL не растягивают карточку */
    word-break: break-word;
  }
  /* единственная «настоящая» ссылка на пост — растягивается на всю карточку через ::before */
  .title-link {
    color: inherit;
    border: 0;
  }
  .title-link::before {
    content: '';
    position: absolute;
    inset: 0;
  }
  .title-link:hover { color: var(--gold-bright); }
  .excerpt {
    color: var(--text-dim);
    font-size: 0.95rem;
    margin: 0 0 0.8rem;
  }
  .footer {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .badge {
    font-family: var(--font-display);
    border: 1px solid var(--gold-dim);
    color: var(--gold-dim);
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
  }
</style>
